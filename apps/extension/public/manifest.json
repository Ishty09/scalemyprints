{
  "manifest_version": 3,
  "name": "ScaleMyPrints — Free Trademark Checker",
  "short_name": "ScaleMyPrints",
  "description": "Check trademark risk on any Etsy, Amazon, or Redbubble listing. Save your shop from takedowns.",
  "version": "0.1.0",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "ScaleMyPrints — Check trademark risk",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png"
    }
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.etsy.com/listing/*",
        "https://www.etsy.com/*/listing/*",
        "https://www.amazon.com/dp/*",
        "https://www.amazon.com/*/dp/*",
        "https://www.amazon.co.uk/dp/*",
        "https://www.amazon.co.uk/*/dp/*",
        "https://www.amazon.com.au/dp/*",
        "https://www.amazon.com.au/*/dp/*",
        "https://www.redbubble.com/i/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "permissions": ["storage"],
  "host_permissions": [
    "https://api.scalemyprints.com/*",
    "http://localhost:8000/*"
  ],
  "web_accessible_resources": [
    {
      "resources": ["icons/*.png"],
      "matches": ["https://www.etsy.com/*", "https://www.amazon.com/*", "https://www.redbubble.com/*"]
    }
  ]
}
