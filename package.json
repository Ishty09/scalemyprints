{
  "name": "scalemyprints",
  "version": "0.1.0",
  "private": true,
  "description": "AI workforce for Print-on-Demand sellers",
  "author": "ScaleMyPrints",
  "license": "UNLICENSED",
  "packageManager": "pnpm@8.15.4",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.15.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "dev:web": "turbo run dev --filter=@scalemyprints/web",
    "dev:extension": "turbo run dev --filter=@scalemyprints/extension",
    "dev:workers": "cd apps/workers && uv run uvicorn scalemyprints.main:app --reload --port 8000",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "test": "turbo run test",
    "test:watch": "turbo run test:watch",
    "test:workers": "cd apps/workers && uv run pytest",
    "type-check": "turbo run type-check",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\" --ignore-path .gitignore",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\" --ignore-path .gitignore",
    "clean": "turbo run clean && rm -rf node_modules .turbo",
    "clean:modules": "find . -name 'node_modules' -type d -prune -exec rm -rf '{}' +",
    "prepare": "husky install || true",
    "db:migrate:new": "supabase migration new",
    "db:push": "supabase db push",
    "db:reset": "supabase db reset",
    "db:types": "supabase gen types typescript --linked > packages/contracts/src/database.types.ts"
  },
  "devDependencies": {
    "@types/node": "^20.11.30",
    "husky": "^9.0.11",
    "lint-staged": "^15.2.2",
    "prettier": "^3.2.5",
    "prettier-plugin-tailwindcss": "^0.5.14",
    "turbo": "^1.13.0",
    "typescript": "^5.4.3"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  }
}
